# AirMind Environment Configurations

# Server Host Settings
HOST=0.0.0.0
PORT=8000

# MongoDB Settings
MONGO_URI=mongodb://localhost:27017
MONGO_DB=airmind

# Security & JWT Tokens
JWT_SECRET=super_secret_airmind_development_key_change_in_production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# External AI APIs
GEMINI_API_KEY=your_gemini_api_key_here
